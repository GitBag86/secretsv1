{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-config-schema/schema.json",
  "productName": "KnowledgeBase",
  "version": "1.0.0",
  "identifier": "com.knowledgebase.app",
  "build": { "frontendDist": "../../apps/frontend/out", "devUrl": "http://localhost:3000", "beforeDevCommand": "cd ../../apps/frontend && npx next dev -p 3000", "beforeBuildCommand": "cd ../../apps/frontend && npx next build" },
  "app": {
    "windows": [{ "title": "KnowledgeBase", "width": 1200, "height": 800, "minWidth": 800, "minHeight": 600, "center": true, "decorations": true }],
    "security": { "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; connect-src 'self' ipc: http://ipc.localhost; img-src 'self' asset: http://asset.localhost" }
  },
  "bundle": { "active": true, "targets": "all", "icon": ["icons/32x32.png", "icons/128x128.png", "icons/128x128@2x.png", "icons/icon.icns", "icons/icon.ico"] }
}
